{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/docs/AGENT_WORKFLOW.md",
    ".opencode/docs/ARCHITECTURE.md",
    ".opencode/docs/DEV_COMMANDS.md",
    ".opencode/docs/DEVELOPMENT_GUIDELINES.md"
  ],
  "permission": {
    "bash": {
      "*": "ask",
      "git status *": "allow",
      "git status": "allow",
      "git diff *": "allow",
      "git log *": "allow",
      "git checkout *": "allow",
      "git add *": "allow",
      "git commit *": "allow",
      "git branch *": "allow",
      "git branch": "allow",
      "git fetch *": "allow",
      "git merge *": "allow",
      "git rebase *": "allow",
      "git stash *": "allow",
      "git reset *": "allow",
      "git restore *": "allow",
      "git show *": "allow",
      "git push *": "allow",
      "git push": "allow",
      "gh *": "allow"
    },
    "skill": {
      "antivibe": "allow"
    }
  },
  "agent": {
    "plan": {
      "model": "github-copilot/claude-opus-4.7",
      "temperature": 0,
      "steps": 15,
      "prompt": "You are in plan mode. Think deeply before responding. Output a structured, minimal plan only — numbered steps, no implementation prose, no filler. Be concise and direct."
    },
    "build": {
      "model": "github-copilot/claude-sonnet-4.6",
      "temperature": 0.1,
      "steps": 50
    },
    "title": {
      "model": "github-copilot/claude-haiku-4.5",
      "steps": 3
    },
    "summary": {
      "model": "github-copilot/claude-haiku-4.5",
      "steps": 5
    },
    "compaction": {
      "model": "github-copilot/claude-haiku-4-5"
    }
  }
}
