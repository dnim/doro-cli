{
  "name": "doro-cli",
  "version": "1.0.0-rc.3",
  "description": "Minimal terminal pomodoro timer with keyboard shortcuts and chiptune cues",
  "files": [
    "dist",
    "!dist/__tests__",
    "CHANGELOG.md",
    "assets"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dnim/doro-cli"
  },
  "homepage": "https://github.com/dnim/doro-cli#readme",
  "bugs": {
    "url": "https://github.com/dnim/doro-cli/issues"
  },
  "main": "dist/cli.js",
  "bin": {
    "doro": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:local": "eslint . --cache",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --runInBand"
  },
  "keywords": [
    "pomodoro",
    "cli",
    "timer"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "blessed": "npm:@rook2pawn/neo-blessed@^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@yao-pkg/pkg": "^6.19.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.29.0"
  }
}
