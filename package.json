{
  "name": "doro-cli",
  "version": "0.1.0",
  "description": "Minimal terminal pomodoro timer with keyboard shortcuts and chiptune cues",
  "main": "dist/cli.js",
  "bin": {
    "doro": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binaries": "npm run build && npx @yao-pkg/pkg . --out-path dist/binaries",
    "dev": "tsx src/cli.ts",
    "lint": "eslint . --ext .ts",
    "lint:local": "eslint . --ext .ts --cache",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --runInBand"
  },
  "keywords": [
    "pomodoro",
    "cli",
    "timer"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "pkg": {
    "scripts": [
      "dist/**/*.js",
      "node_modules/blessed/lib/widgets/*.js"
    ],
    "assets": [
      "node_modules/blessed/usr/**/*"
    ],
    "targets": [
      "node22-macos-x64",
      "node22-macos-arm64",
      "node22-linux-x64",
      "node22-linux-arm64",
      "node22-win-x64"
    ]
  },
  "dependencies": {
    "blessed": "npm:@rook2pawn/neo-blessed@^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/blessed": "^0.1.27",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.14.0",
    "@yao-pkg/pkg": "^6.19.0",
    "eslint": "^9.24.0",
    "globals": "^16.0.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.2.6",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.29.0"
  }
}
